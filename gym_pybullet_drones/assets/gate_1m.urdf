<robot name="robot">
  <link name="base_footprint">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0"/>
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
    </inertial>
  </link>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0.55" rpy="0 0 0" />
  </joint>
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 1.2 0.1" />
      </geometry>
      <material name="base_link-material">
        <color rgba="0.04231141061442144 0.059511238155621766 0.6938717612856897 1" />
      </material>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 1.2 0.1" />
      </geometry>
    </collision> -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0.16666666666666666" ixy="0" ixz="0" iyy="0.16666666666666666" iyz="0" izz="0.16666666666666666" />
    </inertial>
  </link>
  <joint name="base_link_to_y_pos" type="fixed">
    <parent link="base_link" />
    <child link="y_pos" />
    <origin xyz="0 0.55 -0.55" rpy="0 0 0" />
  </joint>
  <link name="y_pos">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.1 1.2" />
      </geometry>
      <material name="y_pos-material">
        <color rgba="0.025186859622305935 0.8879231178794776 0.08865558627723595 1" />
      </material>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.1 1.2" />
      </geometry>
    </collision> -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0.16666666666666666" ixy="0" ixz="0" iyy="0.16666666666666666" iyz="0" izz="0.16666666666666666" />
    </inertial>
  </link>
  <joint name="base_link_to_z_neg" type="fixed">
    <parent link="base_link" />
    <child link="z_neg" />
    <origin xyz="0 0 -1.1" rpy="0 0 0" />
  </joint>
  <link name="z_neg">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 1.2 0.1" />
      </geometry>
      <material name="z_neg-material">
        <color rgba="0 0.9646862478936612 1 1" />
      </material>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 1.2 0.1" />
      </geometry>
    </collision> -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0.16666666666666666" ixy="0" ixz="0" iyy="0.16666666666666666" iyz="0" izz="0.16666666666666666" />
    </inertial>
  </link>
  <joint name="base_link_to_y_neg" type="fixed">
    <parent link="base_link" />
    <child link="y_neg" />
    <origin xyz="0 -0.55 -0.55" rpy="0 0 0" />
  </joint>
  <link name="y_neg">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.1 1.2" />
      </geometry>
      <material name="y_neg-material">
        <color rgba="0 0.9646862478936612 1 1" />
      </material>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.1 1.2" />
      </geometry>
    </collision> -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0.16666666666666666" ixy="0" ixz="0" iyy="0.16666666666666666" iyz="0" izz="0.16666666666666666" />
    </inertial>
  </link>
</robot>